# ── App ──────────────────────────────────────────────
APP_NAME=DuLichViet API
APP_VERSION=2.0.0
ENVIRONMENT=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:5173

# ── Database & Redis ────────────────────────────────
# These defaults match docker-compose.yml. Change only if using different ports.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dulichviet
REDIS_URL=redis://localhost:6379/0

# ── Security ────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# App will warn on startup if this is empty or using the dev default.
JWT_SECRET_KEY=

# ── AI providers / Goong ETL ───────────────────────
GEMINI_API_KEY=
GOONG_API_KEY=
# GOONG_MAP_KEY and GOONG_MAP_API_KEY are accepted aliases for local compatibility.
GOONG_MAP_API_KEY=
# 30s timeout is the code/config default; 120s is safer for local/staging Gemini smoke tests.
# Activity pacing is configurable so MVP smoke tests do not hardcode product behavior.
AGENT_TIMEOUT_SECONDS=120
AGENT_MIN_ACTIVITIES_PER_DAY=5
AGENT_MAX_ACTIVITIES_PER_DAY=5

# ── Email / SMTP ────────────────────────────────────
# Leave SMTP_HOST empty for dev — password reset links log to console instead of email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@dulichviet.local
EMAIL_FROM_NAME=DuLichViet

# ── Optional analytics ──────────────────────────────
# Keep disabled until guardrails are implemented.
ENABLE_ANALYTICS=false
ANALYTICS_DATABASE_URL=
